{
  "name": "Expo Mobile Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8081, 19000, 19001, 19002],
  "portsAttributes": {
    "8081": { "label": "Metro Bundler" },
    "19000": { "label": "Expo DevTools" },
    "19001": { "label": "Expo Tunnel/LAN" },
    "19002": { "label": "Expo DevTools UI" }
  },
  "postCreateCommand": "npm i -g expo-cli eas-cli && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "msjsdiag.vscode-react-native"
      ]
    }
  }
}
