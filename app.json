{
  "expo": {
    "name": "Phone Invasion",
    "slug": "phone-invasion",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "phoneinvasion",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phoneinvasion.app"
    },
    "android": {
      "package": "com.phoneinvasion.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": ["expo-router", "expo-updates"],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "6f3468f5-87d8-4b3a-81bb-b51298dbb01b"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
